{
  "name": "randkeykit",
  "version": "1.0.0",
  "private": true,
  "description": "Client-side cryptographic key and token generator. 100% offline, Web Crypto.",
  "scripts": {
    "build:css": "tailwindcss -i src/styles.css -o assets/tailwind.css --minify",
    "watch:css": "tailwindcss -i src/styles.css -o assets/tailwind.css --watch",
