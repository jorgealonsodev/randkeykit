  },
  "devDependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/material-symbols-outlined": "^5.2.45",
    "linkedom": "^0.18.12",
    "tailwindcss": "^3.4.17"
  }
}
